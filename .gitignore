data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
artifacts/
*.hdf5
*.h5

# ── Model checkpoints & outputs ───────────────────────────────────────────────
*.ckpt
*.pt
*.pth
*.onnx
*.trt
runs/
outputs/
wandb/
mlruns/

# ── CARLA logs ─────────────────────────────────────────────────────────────────
