*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-wheel-metadata/
share/python-wheels/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
.env/

